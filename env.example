# Firebase Configuration
# Copy this file to .env.local and fill in your actual Firebase config values

# =============================================================================
# PRODUCTION FIREBASE CONFIGURATION
# =============================================================================
# Use these settings for production development or testing against real Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# =============================================================================
# EMULATOR CONFIGURATION (for local development)
# =============================================================================
# Uncomment these lines to use Firebase emulators instead of production
# NEXT_PUBLIC_USE_EMULATORS=true
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-word-chaser
# NEXT_PUBLIC_FIREBASE_DATABASE_URL=http://127.0.0.1:9000?ns=demo-word-chaser

# =============================================================================
# FIREBASE CLI CONFIGURATION
# =============================================================================
# Optional: Firebase CLI token for non-interactive emulator runs (do not commit actual token)
# Generate with: npx firebase login:ci
FIREBASE_TOKEN=your-firebase-cli-token

# Optional: Service account credentials for CI/CD and Admin SDK (do not commit actual credentials)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# =============================================================================
# FIREBASE ADMIN SDK CONFIGURATION
# =============================================================================
# For server-side operations (API routes), the Admin SDK is used
# In development with emulators, it uses default credentials
# In production, it requires a service account or built-in Firebase support