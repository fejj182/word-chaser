# E2E Testing Environment Variables
# Copy this to .env.e2e.local for E2E tests

# =============================================================================
# E2E TESTING WITH FIREBASE EMULATORS
# =============================================================================
# These settings ensure E2E tests run against emulators, not production

# Enable Firebase emulators for E2E tests
NEXT_PUBLIC_USE_EMULATORS=true

# Firebase project for emulators (must match src/lib/firebase/config/emulator.json project)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-word-chaser

# Firebase Database URL (emulator)
NEXT_PUBLIC_FIREBASE_DATABASE_URL=http://127.0.0.1:9000?ns=demo-word-chaser

# Firebase Auth Emulator
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# =============================================================================
# FIREBASE CLI CONFIGURATION (for emulator authentication)
# =============================================================================
# Optional: Firebase CLI token for non-interactive emulator runs
# Generate with: npx firebase login:ci
FIREBASE_TOKEN=your-firebase-cli-token

# Optional: Service account for non-interactive auth (alternative to FIREBASE_TOKEN)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
