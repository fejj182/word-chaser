# E2E Testing Environment Variables
# Copy this to .env.e2e.local for E2E tests

# Enable Firebase emulators for E2E tests
NEXT_PUBLIC_USE_EMULATORS=true

# Firebase Auth Emulator
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Firebase Database URL (emulator)
NEXT_PUBLIC_FIREBASE_DATABASE_URL=http://127.0.0.1:9000?ns=demo-word-chaser

# Optional: Service account for non-interactive auth
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
